{
  "lexicon": 1,
  "id": "com.example.getProfile",
  "description": "Fetch a user profile by DID or handle.",
  "defs": {
    "main": {
      "type": "query",
      "description": "Returns profile information for the specified account.",
      "parameters": {
        "type": "params",
        "required": ["actor"],
        "properties": {
          "actor": {
            "type": "string",
            "format": "at-identifier",
            "description": "The DID or handle of the account to fetch."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#profileView"
        }
      },
      "errors": [
        {
          "name": "AccountNotFound",
          "description": "No account exists for the given actor."
        }
      ]
    },
    "profileView": {
      "type": "object",
      "description": "A public view of a user profile.",
      "required": ["did", "handle"],
      "properties": {
        "did": {
          "type": "string",
          "format": "did"
        },
        "handle": {
          "type": "string",
          "format": "handle"
        },
        "displayName": {
          "type": "string",
          "maxGraphemes": 64,
          "maxLength": 640
        },
        "description": {
          "type": "string",
          "maxGraphemes": 256,
          "maxLength": 2560
        },
        "avatar": {
          "type": "string",
          "format": "uri"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime"
        }
      }
    }
  }
}
